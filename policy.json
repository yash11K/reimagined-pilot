{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject","s3:PutObject","s3:ListBucket","s3:DeleteObject"],
      "Resource": ["arn:aws:s3:::s3-customer-success-kb","arn:aws:s3:::s3-customer-success-kb/*"]
    },
    {
      "Effect": "Allow",
      "Action": ["bedrock:InvokeModel","bedrock:InvokeModelWithResponseStream","bedrock:Retrieve","bedrock:RetrieveAndGenerate"],
      "Resource": "*"
    }
  ]
}
